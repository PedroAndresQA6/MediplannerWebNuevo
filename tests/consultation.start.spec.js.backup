    await page.screenshot({ path: 'test-results/exploration-initial.png', fullPage: true });
    console.log('📸 Screenshot inicial guardado: exploration-initial.png');
    
    // Llenar textareas
    const textAreas = page.locator('textarea:not([disabled]):not([readonly])');
    const taCount = await textAreas.count();
