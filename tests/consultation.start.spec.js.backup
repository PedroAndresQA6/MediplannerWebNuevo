            const normalButtons = group.locator('button:has-text("Normal"), button:has-text("normal"), button:has-text("Anormal"), button:has-text("anormal")');
            let btnCount = await normalButtons.count();
            
            if (btnCount > 0) {
              console.log(`🔘 Encontrados ${btnCount} botones de estado en grupo de radios ${i+1}`);
              
              const normalOnlyBtn = group.locator('button:has-text("Normal")');
              if (await normalOnlyBtn.count() > 0 && await normalOnlyBtn.first().isVisible()) {
                await normalOnlyBtn.first().click();
                console.log(`✅ Botón "Normal" clickeado en grupo de radios ${i+1}`);
              } else {
                const firstBtn = normalButtons.first();
                await firstBtn.click();
                console.log(`✅ Botón de estado clickeado en grupo de radios ${i+1}`);
              }
            }
          }
        }
      }
    }
    
    // Manejar checkboxes individuales
    console.log('☑️ Procesando checkboxes individuales...');
    const checkboxes = page.locator('input[type="checkbox"]:not([disabled])');
    const cbCount = await checkboxes.count();
    console.log(`☑️ Encontrados ${cbCount} checkboxes en Exploración`);
    
    let processedCount = 0;
    for (let i = 0; i < cbCount; i++) {
      const checkbox = checkboxes.nth(i);
      if (await checkbox.isVisible() && await checkbox.isEnabled()) {
        const parentGroup = checkbox.locator('xpath=ancestor::*[contains(@class, "group") or contains(@class, "grupo")]');
        const isInGroup = await parentGroup.count() > 0;
        
        if (!isInGroup && processedCount < 15) {
          await checkbox.check();
          console.log(`✅ Checkbox individual ${i+1} marcado`);
          processedCount++;
          
          await page.waitForTimeout(500);
          
          const nearbyInputs = checkbox.locator('xpath=following-sibling::input | xpath=../input | xpath=../following-sibling::input');
          if (await nearbyInputs.count() > 0) {
            const input = nearbyInputs.first();
            if (await input.isVisible()) {
              await input.fill('Detalle');
              console.log(`✅ Input cercano llenado para checkbox ${i+1}`);
            }
          }
          
          const nearbyButtons = checkbox.locator('xpath=following-sibling::button | xpath=../button | xpath=../following-sibling::button');
          let btnCount = await nearbyButtons.count();
          if (btnCount > 0) {
            for (let b = 0; b < btnCount; b++) {
              const btn = nearbyButtons.nth(b);
              const btnText = await btn.textContent();
              if (btnText.toLowerCase().includes('normal')) {
                await btn.click();
                console.log(`✅ Botón "Normal" clickeado para checkbox ${i+1}`);
                break;
              }
            }
          }
        }
      }
    }
    
    // Manejar radios individuales
    console.log('🔘 Procesando radios individuales...');
    const radios = page.locator('input[type="radio"]:not([disabled])');
    const rCount = await radios.count();
    console.log(`🔘 Encontrados ${rCount} radios en Exploración`);
    
    let processedRadios = 0;
    for (let i = 0; i < rCount; i++) {
      const radio = radios.nth(i);
      if (await radio.isVisible() && await radio.isEnabled()) {
        const parentGroup = radio.locator('xpath=ancestor::*[contains(@class, "group") or contains(@class, "grupo")]');
        const isInGroup = await parentGroup.count() > 0;
        
        if (!isInGroup && processedRadios < 20) {
          await radio.check();
          console.log(`✅ Radio individual ${i+1} seleccionado`);
          processedRadios++;
          
          await page.waitForTimeout(500);
          
          const nearbyInputs = radio.locator('xpath=following-sibling::input | xpath=../input | xpath=../following-sibling::input');
          if (await nearbyInputs.count() > 0) {
            const input = nearbyInputs.first();
            if (await input.isVisible()) {
              await input.fill('Detalle');
              console.log(`✅ Input cercano llenado para radio ${i+1}`);
            }
          }
          
          const nearbyButtons = radio.locator('xpath=following-sibling::button | xpath=../button | xpath=../following-sibling::button');
          let btnCount = await nearbyButtons.count();
          if (btnCount > 0) {
            for (let b = 0; b < btnCount; b++) {
              const btn = nearbyButtons.nth(b);
              const btnText = await btn.textContent();
              if (btnText.toLowerCase().includes('normal')) {
                await btn.click();
                console.log(`✅ Botón "Normal" clickeado para radio ${i+1}`);
                break;
              }
            }
          }
        }
      }
    }
    
    // Llenar inputs de texto individuales
    console.log('📥 Procesando inputs de texto individuales...');
    const textInputs = page.locator('input[type="text"]:not([disabled]):not([readonly]), input[type="number"]:not([disabled]):not([readonly])');
    const tiCount = await textInputs.count();
    console.log(`📥 Encontrados ${tiCount} inputs de texto/numero en Exploración`);
    
    for (let i = 0; i < tiCount; i++) {
      const input = textInputs.nth(i);
      if (await input.isVisible() && await input.isEnabled()) {
        const currentValue = await input.inputValue();
        if (!currentValue || currentValue.trim() === '') {
          const inputType = await input.getAttribute('type') || 'text';
          let fillValue = 'N/A';
          
          if (inputType === 'number') {
            fillValue = '0';
          } else if (await input.getAttribute('placeholder')?.toLowerCase().includes('presion')) {
            fillValue = '120/80';
          } else if (await input.getAttribute('placeholder')?.toLowerCase().includes('temperatura')) {
            fillValue = '36.5';
          }
          
          await input.fill(fillValue);
          console.log(`✅ Input ${i+1} llenado: ${fillValue}`);
        }
      }
    }
    
    // Capturar HTML final para análisis
    if (await explorationSection.count() > 0) {
      const finalHtml = await explorationSection.innerHTML();
      await page.screenshot({ path: 'test-results/exploration-final.png', fullPage: true });
      console.log('📸 Screenshot final guardado: exploration-final.png');
      
      if (sectionHtml && finalHtml !== sectionHtml) {
        console.log('🔄 Se detectaron cambios en la estructura HTML de Exploración');
      }
    }
    
    // Buscar y hacer clic en TODOS los botones "Normal" visibles
    console.log('🔍 Buscando todos los botones "Normal" visibles...');
    const allNormalButtons = page.locator('button:has-text("Normal"), button:has-text("normal")');
    const normalCount = await allNormalButtons.count();
    console.log(`🔘 Encontrados ${normalCount} botones "Normal" en la página`);
    
    for (let i = 0; i < normalCount; i++) {
      const btn = allNormalButtons.nth(i);
      if (await btn.isVisible()) {
        try {
          await btn.click();
          console.log(`✅ Botón "Normal" ${i+1} clickeado`);
          await page.waitForTimeout(300);
        } catch (e) {
          console.log(`⚠️ No se pudo clickear botón "Normal" ${i+1}: ${e.message}`);
        }
      }
    }
    
    console.log('✅ Sección de Exploración completada');
  } catch (error) {
    console.log(`⚠️ Error en fillExplorationSection (continuando): ${error.message}`);
  }
}

async function fillTreatmentSection(page) {
  console.log('💊 Iniciando llenado de la sección de Tratamiento...');
   
  // Lista de medicamentos comunes para autocompletado
  const commonMedicines = [
    'Paracetamol 500mg',
    'Ibuprofeno 400mg',
    'Amoxicilina 500mg',
    'Metformina 850mg',
    'Omeprazol 20mg',
    'Losartán 50mg',
    'Atorvastatina 20mg',
    'Aspirina 100mg',
    'Diclofenaco 100mg',
    'Naproxeno 250mg',
    'Tramadol 50mg',
    'Prednisona 5mg',
    'Clonixinato de lisina 125mg',
    'Ranitidina 150mg',
    'Trimebutina 200mg',
    'Bisacodilo 5mg',
    'Loperamida 2mg',
    'Domperidona 10mg',
    'Metoclopramida 10mg',
    'Ciprofloxacino 500mg'
  ];
  
  try {
    await page.waitForTimeout(2000);
    
    // Llenar textareas (cuadros de texto)
    const textAreas = page.locator('textarea:not([disabled]):not([readonly])');
    const taCount = await textAreas.count();
    console.log(`📝 Encontradas ${taCount} textareas en Tratamiento`);
    
    let filledTaCount = 0;
    for (let i = 0; i < taCount; i++) {
      const textarea = textAreas.nth(i);
      if (await textarea.isVisible() && await textarea.isEnabled()) {
        const currentValue = await textarea.inputValue();
        if (!currentValue || currentValue.trim() === '') {
          const placeholder = await textarea.getAttribute('placeholder') || '';
          const name = await textarea.getAttribute('name') || '';
          let fillText = 'Tratamiento indicado según evaluación médica';
          
          if (placeholder.toLowerCase().includes('indicacion') || name.toLowerCase().includes('indicacion')) {
            fillText = 'Indicaciones: Tomar medicamento según prescripción, reposo relativo, dieta adecuada';
          } else if (placeholder.toLowerCase().includes('nota') || name.toLowerCase().includes('nota')) {
            fillText = 'Notas adicionales: Seguimiento en 7 días';
          } else if (placeholder.toLowerCase().includes('receta') || name.toLowerCase().includes('receta')) {
            fillText = 'Receta médica generada';
          } else if (placeholder.toLowerCase().includes('tratamiento') || name.toLowerCase().includes('tratamiento')) {
            fillText = 'Tratamiento farmacológico indicado según diagnóstico';
          }
          
          await textarea.fill(fillText);
          filledTaCount++;
          console.log(`✅ Textarea ${i+1} llenado: ${fillText.substring(0, 50)}...`);
        }
      }
    }
    console.log(`📊 Total textareas llenados: ${filledTaCount}/${taCount}`);
    
    // Manejar dropdowns de medicamentos
    console.log('💊 Buscando dropdowns de medicamentos...');
    
    // Buscar selects (dropdowns) - solo los visibles
    let selects = page.locator('select:not([disabled]):visible');
    let selectCount = await selects.count();
    console.log(`📋 Encontrados ${selectCount} dropdowns visibles en Tratamiento`);
    
    // Buscar también combobox y elementos con role="listbox"
    const comboboxes = page.locator('[role="combobox"]:visible, [role="listbox"]:visible');
    const comboboxCount = await comboboxes.count();
    console.log(`📋 Encontrados ${comboboxCount} combobox/listbox visibles en Tratamiento`);
    
    // Buscar inputs con autocompletado (podrían ser selectores de medicamentos)
    const autocompleteInputs = page.locator('input[list]:visible, input[autocomplete="off"]:visible, input[role="combobox"]:visible, input[aria-autocomplete]:visible');
    const autocompleteCount = await autocompleteInputs.count();
    console.log(`📋 Encontrados ${autocompleteCount} inputs con autocompletado visibles en Tratamiento`);
    
    // Procesar dropdowns visibles
    if (selectCount > 0) {
      for (let i = 0; i < selectCount; i++) {
        const select = selects.nth(i);
        try {
          const options = await select.locator('option').count();
          console.log(`📋 Dropdown ${i+1} tiene ${options} opciones`);
          
          // Verificar si las opciones están cargadas (no "Cargando...")
          let optionsLoaded = false;
          for (let j = 0; j < Math.min(options, 3); j++) {
            const optionText = await select.locator('option').nth(j).textContent();
            console.log(`   Opción ${j}: "${optionText.trim().substring(0, 30)}..."`);
            if (!optionText.toLowerCase().includes('cargando')) {
              optionsLoaded = true;
            }
          }
          
          if (optionsLoaded && options > 1) {
            // Seleccionar opción aleatoria (excluyendo la primera si es "Seleccione...")
            let randomIndex = Math.floor(Math.random() * (options - 1)) + 1;
            await select.selectOption({ index: randomIndex, timeout: 5000 });
            const selectedOption = await select.locator('option').nth(randomIndex).textContent();
            console.log(`✅ Dropdown ${i+1} seleccionado opción ${randomIndex}: "${selectedOption.trim().substring(0, 40)}..."`);
          } else {
            console.log(`⚠️ Dropdown ${i+1} opciones no cargadas aún`);
          }
        } catch (e) {
          console.log(`⚠️ Error con dropdown ${i+1}: ${e.message.substring(0, 50)}...`);
        }
      }
    }
    
    // Procesar comboboxes
    if (comboboxCount > 0) {
      for (let i = 0; i < Math.min(comboboxCount, 3); i++) {
        const combobox = comboboxes.nth(i);
        try {
          console.log(`📋 Procesando combobox ${i+1}`);
          await combobox.click({ timeout: 3000 });
          await page.waitForTimeout(800);
          
          // Buscar opciones que aparecieron
          const options = page.locator('[role="option"]:visible, [role="menuitem"]:visible, .dropdown-item:visible');
          const optionCount = await options.count();
          if (optionCount > 0) {
            console.log(`📋 Encontradas ${optionCount} opciones en combobox ${i+1}`);
            // Mostrar primeras 3 opciones
            for (let j = 0; j < Math.min(optionCount, 3); j++) {
              const optionText = await options.nth(j).textContent();
              console.log(`   Opción ${j}: "${optionText.trim().substring(0, 30)}..."`);
            }
            const randomIndex = Math.floor(Math.random() * optionCount);
            await options.nth(randomIndex).click({ timeout: 3000 });
            const optionText = await options.nth(randomIndex).textContent();
            console.log(`✅ Combobox ${i+1} seleccionada opción: "${optionText.trim().substring(0, 40)}..."`);
          }
          await page.waitForTimeout(300);
        } catch (e) {
          console.log(`⚠️ Error procesando combobox ${i+1}: ${e.message.substring(0, 50)}...`);
        }
      }
    }
    
    // Procesar inputs con autocompletado
    if (autocompleteCount > 0) {
      for (let i = 0; i < Math.min(autocompleteCount, 3); i++) {
        const input = autocompleteInputs.nth(i);
        try {
          const currentValue = await input.inputValue();
          const placeholder = await input.getAttribute('placeholder') || '';
          const name = await input.getAttribute('name') || '';
          console.log(`📋 Input autocompletado ${i+1}: placeholder="${placeholder}", name="${name}"`);
          
          if (!currentValue || currentValue.trim() === '') {
            const randomMedicine = commonMedicines[Math.floor(Math.random() * commonMedicines.length)];
            await input.fill(randomMedicine, { timeout: 3000 });
            console.log(`✅ Input autocompletado ${i+1} llenado con: "${randomMedicine}"`);
            
            await page.waitForTimeout(1000);
            
            // Buscar sugerencias
            const suggestions = page.locator('[role="option"]:visible, [role="listbox"] *:visible, datalist option, .suggestion-item:visible, .autocomplete-item:visible');
            const suggestionCount = await suggestions.count();
            if (suggestionCount > 0) {
              console.log(`📋 Encontradas ${suggestionCount} sugerencias`);
              const randomSugg = Math.floor(Math.random() * Math.min(suggestionCount, 5));
              await suggestions.nth(randomSugg).click({ timeout: 3000 });
              const suggestionText = await suggestions.nth(randomSugg).textContent();
              console.log(`✅ Sugerencia seleccionada: "${suggestionText.trim().substring(0, 40)}..."`);
            }
            await page.waitForTimeout(300);
          }
        } catch (e) {
          console.log(`⚠️ Error procesando input autocompletado ${i+1}: ${e.message.substring(0, 50)}...`);
        }
      }
    }
    
    // Manejar combobox/autocompletado de medicamentos (ya manejado arriba)
    console.log('🔍 Buscando inputs con autocompletado de medicamentos específicos...');
    
    const medicInputs = page.locator('input[placeholder*="medic" i], input[placeholder*="farmaco" i], input[placeholder*="receta" i], input[name*="medic" i], input[name*="drug" i]');
    const medicCount = await medicInputs.count();
    console.log(`💊 Encontrados ${medicCount} inputs de medicamentos específicos`);
    
    for (let i = 0; i < medicCount; i++) {
      const input = medicInputs.nth(i);
      if (await input.isVisible() && await input.isEnabled()) {
        const currentValue = await input.inputValue();
        if (!currentValue || currentValue.trim() === '') {
          const randomMedicine = commonMedicines[Math.floor(Math.random() * commonMedicines.length)];
          await input.fill(randomMedicine);
          console.log(`✅ Input de medicamento ${i+1} llenado con: "${randomMedicine}"`);
          
          await page.waitForTimeout(1000);
          
          const suggestions = page.locator('.autocomplete-suggestion, .dropdown-item, [role="option"], [class*="suggestion"], [class*="option"]');
          const suggestionCount = await suggestions.count();
          
          if (suggestionCount > 0) {
            console.log(`📋 Encontradas ${suggestionCount} sugerencias para medicamento ${i+1}`);
            await suggestions.first().click();
            console.log(`✅ Primera sugerencia seleccionada para medicamento ${i+1}`);
          }
        }
      }
    }
    
    // Llenar inputs de texto individuales
    console.log('📥 Procesando inputs de texto en Tratamiento...');
    const textInputs = page.locator('input[type="text"]:not([disabled]):not([readonly]), input[type="number"]:not([disabled]):not([readonly])');
    const tiCount = await textInputs.count();
    console.log(`📥 Encontrados ${tiCount} inputs de texto/numero en Tratamiento`);
    
    for (let i = 0; i < tiCount; i++) {
      const input = textInputs.nth(i);
      if (await input.isVisible() && await input.isEnabled()) {
        const currentValue = await input.inputValue();
        if (!currentValue || currentValue.trim() === '') {
          const placeholder = await input.getAttribute('placeholder') || '';
          const name = await input.getAttribute('name') || '';
          const inputType = await input.getAttribute('type') || 'text';
          
          let fillValue = '';
          
          // Determinar qué llenar basado en el contexto
          if (placeholder.toLowerCase().includes('dosis') || name.toLowerCase().includes('dosis')) {
            fillValue = '1 tableta';
          } else if (placeholder.toLowerCase().includes('frecuencia') || name.toLowerCase().includes('frecuencia')) {
            fillValue = 'Cada 8 horas';
          } else if (placeholder.toLowerCase().includes('duracion') || name.toLowerCase().includes('duracion')) {
            fillValue = '7 días';
          } else if (placeholder.toLowerCase().includes('cantidad') || name.toLowerCase().includes('cantidad')) {
            fillValue = '1';
          } else if (placeholder.toLowerCase().includes('via') || name.toLowerCase().includes('via')) {
            fillValue = 'Oral';
          } else if (inputType === 'number') {
            fillValue = '1';
          } else {
            fillValue = 'Tratamiento indicado';
          }
          
          await input.fill(fillValue);
          console.log(`✅ Input ${i+1} llenado con: "${fillValue}"`);
        }
      }
    }
    
    console.log('✅ Sección de Tratamiento completada');
  } catch (error) {
    console.log(`⚠️ Error en fillTreatmentSection (continuando): ${error.message}`);
  }
}

async function fillServicesSection(page) {
  console.log('💉 Iniciando llenado de la sección de Servicios...');
   
  try {
    await page.waitForTimeout(2000);
    
    const textAreas = page.locator('textarea:not([disabled]):not([readonly])');
    const taCount = await textAreas.count();
    console.log(`📝 Encontradas ${taCount} textareas en Servicios`);
    
    for (let i = 0; i < taCount; i++) {
      const textarea = textAreas.nth(i);
      if (await textarea.isVisible() && await textarea.isEnabled()) {
        const currentValue = await textarea.inputValue();
        if (!currentValue || currentValue.trim() === '') {
          const placeholder = await textarea.getAttribute('placeholder') || '';
          let fillText = 'Servicio médico registrado';
          
          if (placeholder.toLowerCase().includes('certificado')) {
            fillText = 'Certificado médico de reposo laboral por 3 días';
          } else if (placeholder.toLowerCase().includes('servicio')) {
            fillText = 'Consulta general con signos vitales';
          } else if (i === 0) {
            fillText = 'Servicios de salud solicitados según evaluación médica';
          }
          
          await textarea.fill(fillText);
          console.log(`✅ Textarea ${i+1} llenado: ${fillText.substring(0, 50)}...`);
        }
      }
    }
    
    const checkboxes = page.locator('input[type="checkbox"]:not([disabled])');
    const cbCount = await checkboxes.count();
    console.log(`☑️ Encontrados ${cbCount} checkboxes en Servicios`);
    
    for (let i = 0; i < cbCount; i++) {
      const checkbox = checkboxes.nth(i);
      if (await checkbox.isVisible() && await checkbox.isEnabled()) {
        if (i % 3 === 0) {
          await checkbox.check();
          console.log(`✅ Checkbox de servicio ${i+1} marcado`);
        }
      }
    }
    
    const radios = page.locator('input[type="radio"]:not([disabled])');
    const rCount = await radios.count();
    console.log(`🔘 Encontrados ${rCount} radios en Servicios`);
    
    for (let i = 0; i < rCount; i++) {
      const radio = radios.nth(i);
      if (await radio.isVisible() && await radio.isEnabled()) {
        if (i % 2 === 0) {
          await radio.check();
          console.log(`✅ Radio ${i+1} seleccionado`);
        }
      }
    }
    
    const textInputs = page.locator('input[type="text"]:not([disabled]):not([readonly]), input[type="number"]:not([disabled]):not([readonly])');
    const tiCount = await textInputs.count();
    console.log(`📥 Encontrados ${tiCount} inputs de texto/numero en Servicios`);
    
    for (let i = 0; i < tiCount; i++) {
      const input = textInputs.nth(i);
      if (await input.isVisible() && await input.isEnabled()) {
        const currentValue = await input.inputValue();
        if (!currentValue || currentValue.trim() === '') {
          const inputType = await input.getAttribute('type') || 'text';
          let fillValue = 'N/A';
          
          if (inputType === 'number') {
            fillValue = '1';
          } else if (await input.getAttribute('placeholder')?.toLowerCase().includes('dias') || 
                     await input.getAttribute('placeholder')?.toLowerCase().includes('día')) {
            fillValue = '3';
          } else if (await input.getAttribute('placeholder')?.toLowerCase().includes('cantidad')) {
            fillValue = '1';
          }
          
          await input.fill(fillValue);
          console.log(`✅ Input ${i+1} llenado: ${fillValue}`);
        }
      }
    }
    
    console.log('✅ Sección de Servicios completada');
  } catch (error) {
    console.log(`⚠️ Error en fillServicesSection (continuando): ${error.message}`);
  }
}

