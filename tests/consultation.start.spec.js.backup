await guardarSignos.click();

console.log('⏳ Esperando después de guardar signos vitales...');
await page.waitForTimeout(2000);

const cerrarButton = page.getByRole('button', { name: /cerrar/i });
if (await cerrarButton.isVisible().catch(() => false)) {
  console.log('🔘 Haciendo clic en botón cerrar...');
  await cerrarButton.click();
  await page.waitForTimeout(1500);
}

let currentUrl = page.url();
console.log(`📍 URL actual después de guardar: ${currentUrl}`);

console.log('🔄 Esperando redirección a la página de consulta...');
try {
  await page.waitForURL(/Consulta\/(ConsultaGeneral|ConsultaDetalles)/, { timeout: 15000 });
  console.log('✅ Redirigido a página de consulta');
} catch (e) {
  console.log('⚠️ Timeout esperando redirección, verificando estado actual...');
  currentUrl = page.url();
  console.log(`📍 URL actual: ${currentUrl}`);
  
  if (!currentUrl.includes('Consulta')) {
    console.log('🔄 Intentando navegar a ConsultaGeneral...');
    await page.goto('/Consulta/ConsultaGeneral');
    await page.waitForTimeout(3000);
  }
}

const tabs = [
  { name: 'General', fields: ['hospital', 'tipo de consulta', 'motivo de la consulta', 'padecimiento actual', 'notas de evolución', 'nombre de referido'] },
  { name: 'Exploración', fields: [] },
  { name: 'Diagnóstico', fields: [] },
  { name: 'Tratamiento', fields: [] },
  { name: 'Notas del Médico', fields: [] },
  { name: 'Servicios', fields: [] }
];

for (const tabInfo of tabs) {
  const tabName = tabInfo.name;
  const requiredFields = tabInfo.fields;
  
  console.log(`🔍 Buscando pestaña: ${tabName}`);
  
  const tabSelectors = [
    page.getByRole('tab', { name: new RegExp(`^${tabName.replace('ó', 'ó').replace('é', 'é')}$`, 'i') }),
    page.getByRole('button', { name: new RegExp(`^${tabName.replace('ó', 'ó').replace('é', 'é')}$`, 'i') }),
    page.locator(`div, span, p, li, a`).filter({ hasText: new RegExp(`^${tabName.replace('ó', 'ó').replace('é', 'é')}$`, 'i') }),
    page.locator(`div, span, p, li, a:has-text("${tabName}")`),
    page.locator(`.tab, .tabs-item, .nav-tab, [role="tablist"] >> *:has-text("${tabName}")`),
    page.locator(`[data-tab="${tabName}"], [data-tab-name="${tabName}"]`)
  ];
  
  let tabElement = null;
  let tabFound = false;
  
  for (const selector of tabSelectors) {
    try {
      if (await selector.count() > 0) {
        const element = selector.first();
        if (await element.isVisible()) {
          tabElement = element;
          tabFound = true;
          console.log(`✅ Pestaña "${tabName}" encontrada usando selector: ${selector}`);
          break;
        }
      }
    } catch (e) {
      continue;
    }
  }
  
  if (!tabFound) {
    console.log(`⚠️ Pestaña "${tabName}" no visible después de múltiples intentos, saltando...`);
    continue;
  }
  
  console.log(`📝 Haciendo clic en pestaña: ${tabName}`);
  
  // Manejar modales antes de hacer clic
  await handleModals(page);
  await page.waitForTimeout(500);
  
  await tabElement.click();
  
  await page.waitForLoadState('networkidle');
  await page.waitForTimeout(2000);
  
  if (requiredFields.length > 0) {
    console.log(`🎯 Llenando campos específicos para ${tabName}: ${requiredFields.join(', ')}`);
    for (const fieldName of requiredFields) {
      await fillSpecificField(page, fieldName);
    }
  }
  
  console.log(`🔧 Llenando todos los campos disponibles en ${tabName}`);
  
  if (tabName === 'Exploración') {
    await fillExplorationSection(page);
  } else if (tabName === 'Tratamiento') {
    await fillTreatmentSection(page);
  } else {
    await fillTabFields(page, tabName);
  }
  
  if (requiredFields.length > 0) {
    console.log(`✅ Verificando que los campos requeridos de ${tabName} estén llenos`);
  }
  
  console.log(`🔍 Buscando botón de continuar/guardar en ${tabName}...`);
  
  const continuarSelectors = [
    page.getByRole('button', { name: /guardar y continuar/i }),
    page.getByRole('button', { name: /guardar.*continuar/i }),
    page.getByRole('button', { name: /continuar.*guardar/i }),
    page.getByRole('button', { name: /continuar/i }),
    page.getByRole('button', { name: /guardar/i }),
    page.locator('button:has-text("Guardar y continuar")'),
    page.locator('button:has-text("guardar y continuar")'),
    page.locator('button:has-text("Continuar")'),
    page.locator('button:has-text("continuar")'),
    page.locator('button:has-text("Guardar")'),
    page.locator('button:has-text("guardar")'),
    page.locator('button:has-text("Siguiente")'),
    page.locator('button:has-text("siguiente")'),
    page.locator('button:has-text("Next")'),
    page.locator('button:has-text("next")')
  ];
  
  let continuarBtn = null;
  let continuarBtnText = '';
  
  const allButtons = page.locator('button, [role="button"]');
  const buttonCount = await allButtons.count();
  if (buttonCount > 0 && buttonCount < 20) {
    console.log(`📋 Botones disponibles en ${tabName}:`);
    for (let i = 0; i < Math.min(buttonCount, 10); i++) {
      const btn = allButtons.nth(i);
      if (await btn.isVisible()) {
        const btnText = await btn.textContent();
        console.log(`   ${i+1}: "${btnText.trim()}"`);
      }
    }
  }
  
  for (const selector of continuarSelectors) {
    try {
      if (await selector.count() > 0) {
        const btn = selector.first();
        if (await btn.isVisible() && await btn.isEnabled()) {
          continuarBtn = btn;
          continuarBtnText = await btn.textContent();
          console.log(`✅ Botón de continuar/guardar encontrado: "${continuarBtnText.trim()}"`);
          break;
        }
      }
    } catch (e) {
      continue;
    }
  }
  
  if (continuarBtn) {
    console.log('💾 Guardando y continuando...');
    await continuarBtn.click();
    await page.waitForTimeout(1500);
    await page.waitForLoadState('networkidle');
  } else {
    console.log(`ℹ️ Botón 'Guardar y continuar' no encontrado en ${tabName}`);
    console.log('🔄 Intentando avanzar a la siguiente pestaña directamente...');
    
    const tabNameList = ['General', 'Exploración', 'Diagnóstico', 'Tratamiento', 'Notas del Médico', 'Servicios'];
    const currentTabIndex = tabNameList.indexOf(tabName);
    if (currentTabIndex >= 0 && currentTabIndex < tabNameList.length - 1) {
      const nextTabName = tabNameList[currentTabIndex + 1];
      console.log(`⏭️ Intentando ir directamente a la pestaña de ${nextTabName}`);
      
      const nextTabSelectors = [
        page.getByRole('tab', { name: new RegExp(`^${nextTabName.replace('ó', 'ó').replace('é', 'é')}$`, 'i') }),
        page.getByRole('button', { name: new RegExp(`^${nextTabName.replace('ó', 'ó').replace('é', 'é')}$`, 'i') }),
        page.locator(`div, span, p, li, a:has-text("${nextTabName}")`),
        page.locator(`text="${nextTabName}"`)
      ];
      
      let nextTabFound = false;
      for (const selector of nextTabSelectors) {
        try {
          if (await selector.count() > 0) {
            const tabElement = selector.first();
            if (await tabElement.isVisible()) {
              await tabElement.click();
              console.log(`✅ Navegado directamente a la pestaña de ${nextTabName}`);
              nextTabFound = true;
              break;
            }
          }
        } catch (e) {
          continue;
        }
      }
      
      if (!nextTabFound) {
        console.log(`⚠️ No se pudo navegar directamente a ${nextTabName}, continuando con llenado genérico`);
      }
    } else {
      console.log(`ℹ️ ${tabName} es la última pestaña o no se pudo determinar el orden`);
    }
  }
}

// ===========================================
// FINALIZACIÓN DE LA CONSULTA
// ===========================================
console.log('\n🏁 === INICIANDO FINALIZACIÓN DE CONSULTA ===');

await page.waitForTimeout(2000);
await page.waitForLoadState('networkidle');

const finalizarBtn = await waitForFinalizarButton(page);

if (finalizarBtn) {
  console.log('✅ Haciendo clic en Finalizar Consulta...');
  
  await handleModals(page);
  
  await finalizarBtn.click();
  await page.waitForTimeout(2000);
  
  const confirmSelectors = [
    page.getByRole('button', { name: /confirmar/i }),
    page.getByRole('button', { name: /aceptar/i }),
    page.getByRole('button', { name: /sí/i }),
    page.getByRole('button', { name: /si/i }),
    page.locator('button:has-text("Confirmar")'),
    page.locator('button:has-text("Aceptar")'),
    page.locator('.swal2-confirm'),
  ];
  
  for (const selector of confirmSelectors) {
    try {
      if (await selector.count() > 0 && await selector.first().isVisible()) {
        console.log('🔘 Encontrado botón de confirmación, haciendo clic...');
        await selector.first().click();
        await page.waitForTimeout(2000);
        break;
      }
    } catch (e) {
      // Continuar con siguiente selector
    }
  }
  
  console.log('⏳ Esperando redirección después de finalizar...');
  await page.waitForTimeout(3000);
  
  const currentUrl = page.url();
  console.log(`📍 URL actual: ${currentUrl}`);
  
  if (currentUrl.includes('Dashboard') || currentUrl.includes('Citas') || currentUrl.includes('Inicio')) {
    console.log('✅ Consulta finalizada exitosamente - Redirigido al Dashboard');
  } else {
    const successMessages = [
      'Consulta finalizada',
      'Consulta guardada',
      'Operación exitosa',
      'Guardado correctamente'
    ];
    
    let successFound = false;
    for (const msg of successMessages) {
      const successLocator = page.locator(`text=/${msg}/i`);
      if (await successLocator.count() > 0 && await successLocator.first().isVisible()) {
        console.log(`✅ Mensaje de éxito encontrado: "${msg}"`);
        successFound = true;
        break;
      }
    }
    
    if (!successFound) {
      console.log('⚠️ No se detectó mensaje de éxito claro, pero no hubo errores');
    }
  }
  
  await page.screenshot({ path: 'test-results/consultation-finalized.png', fullPage: true });
  console.log('📸 Screenshot guardado: consultation-finalized.png');
  
  console.log('\n🎉 === CONSULTA COMPLETADA EXITOSAMENTE ===');
  
} else {
  console.log('❌ No se pudo encontrar el botón de finalizar consulta');
  await page.screenshot({ path: 'test-results/consultation-no-finalize-btn.png', fullPage: true });
  throw new Error('No se encontró el botón de finalizar consulta');
}

});
